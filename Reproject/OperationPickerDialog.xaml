<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Reproject.OperationPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reproject"
    x:Uid="OperationDialog"
    Title="Select transformation"
    PrimaryButtonText="Select"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind VM.CanSelect, Mode=OneWay}"
    PrimaryButtonClick="OnPrimary">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1100</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">800</x:Double>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
    </ContentDialog.Resources>

    <Grid Width="620" Height="460" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Explains why the dialog appeared; the actual system names are in the status bar. -->
        <TextBlock x:Uid="OperationHint" Grid.Row="0"
                   Text="Several transformations are available. Pick one — they are ordered from most to least precise."
                   TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind VM.Operations}"
                  SelectedItem="{x:Bind VM.SelectedOperation, Mode=TwoWay}"
                  SelectionMode="Single"
                  DoubleTapped="OnItemDoubleTapped"
                  ScrollViewer.HorizontalScrollMode="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:OperationRow">
                    <StackPanel Spacing="2" Padding="4,8">
                        <TextBlock Text="{x:Bind Name}" TextWrapping="Wrap"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind MetaText}" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind Area}" TextWrapping="Wrap"
                                   Visibility="{x:Bind HasArea, Converter={StaticResource BoolToVis}}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind GridFiles}" TextWrapping="Wrap"
                                   Visibility="{x:Bind HasGridFiles, Converter={StaticResource BoolToVis}}"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                        <HyperlinkButton Content="{x:Bind DownloadLabel}"
                                         NavigateUri="{x:Bind DownloadUri}"
                                         Visibility="{x:Bind HasDownload, Converter={StaticResource BoolToVis}}"
                                         Padding="0" Margin="0,2,0,0" />
                        <TextBlock Text="{x:Bind Scope}" TextWrapping="Wrap"
                                   Visibility="{x:Bind HasScope, Converter={StaticResource BoolToVis}}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="{x:Bind Remarks}" TextWrapping="Wrap"
                                   Visibility="{x:Bind HasRemarks, Converter={StaticResource BoolToVis}}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentDialog>

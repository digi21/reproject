<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Reproject.EpsgPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Reproject"
    x:Uid="PickerDialog"
    Title="Seleccionar sistema de referencia de coordenadas"
    PrimaryButtonText="Seleccionar"
    CloseButtonText="Cancelar"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind VM.CanSelect, Mode=OneWay}"
    PrimaryButtonClick="OnPrimary">

    <ContentDialog.Resources>
        <!-- ContentDialog clamps its width to ~548px by default; widen it so the picker fits. -->
        <x:Double x:Key="ContentDialogMaxWidth">1100</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">800</x:Double>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
    </ContentDialog.Resources>

    <Grid Width="920" Height="620" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Categories -->
        <ListView x:Name="CategoryList" Grid.Column="0"
                  ItemsSource="{x:Bind VM.Categories}"
                  SelectedIndex="{x:Bind VM.SelectedCategoryIndex, Mode=TwoWay}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" />

        <!-- Right side -->
        <Grid Grid.Column="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Mode panels (only one visible at a time) -->
            <Grid Grid.Row="0">

                <!-- List mode (geographic 2D/3D, projected, vertical): a type-to-search box, like compound -->
                <StackPanel Spacing="8" Visibility="{x:Bind VM.IsListMode, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <AutoSuggestBox x:Uid="SearchBox" PlaceholderText="Buscar por código EPSG o nombre…"
                                    ItemsSource="{x:Bind VM.ListSuggestions, Mode=OneWay}"
                                    Text="{x:Bind VM.ListText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TextMemberPath="Display" QueryIcon="Find"
                                    TextChanged="OnListTextChanged"
                                    SuggestionChosen="OnListChosen">
                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate x:DataType="local:CrsRow">
                                <TextBlock Text="{x:Bind Display}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>
                </StackPanel>

                <!-- Compound mode (horizontal + vertical) -->
                <StackPanel Spacing="8" Visibility="{x:Bind VM.IsCompoundMode, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock x:Uid="HorizontalLabel" Text="Sistema de coordenadas horizontal" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <AutoSuggestBox x:Uid="HorizontalSuggest" PlaceholderText="Buscar horizontal (proyectado / geográfico)…"
                                    ItemsSource="{x:Bind VM.HorizontalSuggestions, Mode=OneWay}"
                                    Text="{x:Bind VM.HorizontalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TextMemberPath="Display" QueryIcon="Find"
                                    TextChanged="OnHorizontalTextChanged"
                                    SuggestionChosen="OnHorizontalChosen">
                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate x:DataType="local:CrsRow">
                                <TextBlock Text="{x:Bind Display}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>
                    <TextBlock x:Uid="VerticalLabel" Text="Sistema de coordenadas vertical" Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Margin="0,8,0,0" />
                    <CheckBox x:Uid="UnknownVerticalCheck" Content="Vertical desconocido"
                              IsChecked="{x:Bind VM.UnknownVertical, Mode=TwoWay}" />
                    <AutoSuggestBox x:Uid="VerticalSuggest" PlaceholderText="Buscar vertical…"
                                    ItemsSource="{x:Bind VM.VerticalSuggestions, Mode=OneWay}"
                                    IsEnabled="{x:Bind VM.CompoundVerticalEnabled, Mode=OneWay}"
                                    Text="{x:Bind VM.VerticalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TextMemberPath="Display" QueryIcon="Find"
                                    TextChanged="OnVerticalTextChanged"
                                    SuggestionChosen="OnVerticalChosen">
                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate x:DataType="local:CrsRow">
                                <TextBlock Text="{x:Bind Display}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>
                </StackPanel>

                <!-- Manual WKT mode -->
                <Grid RowSpacing="8" Visibility="{x:Bind VM.IsManualMode, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button x:Uid="ImportPrjButton" Content="Importar .prj…" Command="{x:Bind VM.ImportPrjCommand}" />
                        <Button x:Uid="ValidateButton" Content="Validar" Command="{x:Bind VM.ValidateManualCommand}" />
                    </StackPanel>
                    <TextBox x:Uid="ManualWktBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Consolas" PlaceholderText="Pega aquí el WKT del sistema de coordenadas…"
                             Text="{x:Bind VM.ManualWkt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>

                <!-- Favorites mode -->
                <Grid RowSpacing="8" Visibility="{x:Bind VM.IsFavoritesMode, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button x:Uid="RemoveFavButton" Grid.Row="0" Content="Quitar" Command="{x:Bind VM.RemoveFavoriteCommand}" />
                    <ListView Grid.Row="1" SelectionMode="Single"
                              ItemsSource="{x:Bind VM.Favorites, Mode=OneWay}"
                              SelectedItem="{x:Bind VM.SelectedFavorite, Mode=TwoWay}"
                              DoubleTapped="OnItemDoubleTapped"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:CrsSelection">
                                <TextBlock Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" Padding="0,2" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Busy overlay for the initial enumeration -->
                <ProgressRing IsActive="{x:Bind VM.IsBusy, Mode=OneWay}" Width="40" Height="40"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>

            <!-- Detail pane -->
            <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Text="{x:Bind VM.DetailName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                               Text="{x:Bind VM.DetailMeta, Mode=OneWay}" />
                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                               Text="{x:Bind VM.DetailDatum, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <TextBlock x:Uid="AxisOrderLabel" Text="Orientación de ejes" VerticalAlignment="Center" />
                        <ComboBox MinWidth="140"
                                  IsEnabled="{x:Bind VM.AxisOrderEnabled, Mode=OneWay}"
                                  SelectedIndex="{x:Bind VM.SelectedAxisOrderIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{x:Bind VM.StandardAxisLabel, Mode=OneWay}" />
                            <ComboBoxItem x:Uid="AxisEastNorthItem" Content="Este-Norte" />
                            <ComboBoxItem x:Uid="AxisNorthEastItem" Content="Norte-Este" />
                        </ComboBox>
                    </StackPanel>
                    <Expander Header="WKT" HorizontalAlignment="Stretch" Margin="0,4,0,0">
                        <TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 FontFamily="Consolas" Height="110"
                                 Text="{x:Bind VM.WktPreview, Mode=OneWay}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Expander>
                </StackPanel>
            </Border>

            <!-- Action bar -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                <Button x:Uid="CopyWktButton" Content="Copiar WKT" Command="{x:Bind VM.CopyWktCommand}" />
                <Button x:Uid="ExportPrjButton" Content="Exportar .prj…" Command="{x:Bind VM.ExportPrjCommand}" />
                <Button x:Uid="MemorizeButton" Content="Memorizar" Command="{x:Bind VM.MemorizeCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</ContentDialog>

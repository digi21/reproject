    <ClInclude Include="CrsInfo.h" />
    <ClInclude Include="CrsDetails.h" />
    <ClInclude Include="CoordinateOperationInfo.h" />
    <ClInclude Include="Transformation.h" />
    <ClInclude Include="CrsEngine.h" />
  </ItemGroup>
  <ItemGroup>
    <ClCompile Include="pch.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
    </ClCompile>
    <ClCompile Include="CrsInfo.cpp" />
    <ClCompile Include="CrsDetails.cpp" />
    <ClCompile Include="CoordinateOperationInfo.cpp" />
    <ClCompile Include="Transformation.cpp" />
    <ClCompile Include="CrsEngine.cpp" />
    <ClCompile Include="$(GeneratedFilesDir)module.g.cpp" />
  </ItemGroup>
  <ItemGroup>
    <Midl Include="CrsInfo.idl" />

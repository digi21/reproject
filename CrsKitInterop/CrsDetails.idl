namespace CrsKitInterop
{
    // Axis order to bake into the WKT of a horizontal CRS.
    enum AxisOrder
    {
        Default,     // as defined by the EPSG catalogue
        EastNorth,   // longitude/easting first
        NorthEast    // latitude/northing first
    };

    // Read-only descriptive metadata of one CRS, for the picker's detail pane.
    // Created internally (winrt::make) and only returned across the ABI.
    runtimeclass CrsDetails
    {
        Int32  Code{ get; };
        String Name{ get; };
        String Kind{ get; };        // "projected", "geographic 2D", "vertical", ...
        Int32  AxisCount{ get; };   // 1, 2 or 3 (for slot/dimensionality validation)
        String AreaOfUse{ get; };
        String DatumName{ get; };
        String DatumOrigin{ get; };
        String PrimeMeridian{ get; };
        String Ellipsoid{ get; };
    }
}
